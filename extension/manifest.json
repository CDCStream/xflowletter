{
  "manifest_version": 3,
  "name": "X Flow Teller",
  "version": "1.0.1",
  "description": "Read X (Twitter) posts aloud — zero-cost, offline-friendly, no cloud API.",
  "homepage_url": "https://xflowteller.com",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "offscreen"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://api.polar.sh/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["lang-detect.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/logo.svg", "icons/logo-panel.png"],
      "matches": ["https://x.com/*", "https://twitter.com/*"]
    }
  ]
}
